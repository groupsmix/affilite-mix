# ── Required ─ Supabase ──────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://xxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ── Required ─ Auth ──────────────────────────────────────
JWT_SECRET=change-me-to-a-random-64-byte-hex-string
ADMIN_PASSWORD=change-me-fallback-admin-password

# ── Required (production) ─ Cron jobs ────────────────────
CRON_SECRET=change-me-to-a-random-string

# ── Optional ─ Email (Resend) ────────────────────────────
RESEND_API_KEY=
NEWSLETTER_FROM_EMAIL=

# ── Optional ─ Image storage (Cloudflare R2) ─────────────
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_URL=

# ── Optional ─ CAPTCHA (Cloudflare Turnstile) ────────────
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# ── Optional ─ Cloudflare API (cache purge, deploy) ──────
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ZONE_ID=
CLOUDFLARE_ACCOUNT_ID=

# ── Optional ─ Multi-site development ────────────────────
# Controls which site localhost resolves to (e.g. watch-tools, crypto-tools)
NEXT_PUBLIC_DEFAULT_SITE=
